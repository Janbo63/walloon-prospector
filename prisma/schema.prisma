datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Geological & Prospecting Models ─────────────────────────────────────────

model FieldWalk {
  id           String     @id @default(cuid())
  date         DateTime
  startTime    String?    @map("start_time")
  endTime      String?    @map("end_time")
  routeName    String     @map("route_name")
  weather      String?
  dogCompanion String?    @map("dog_companion")
  notes        String?    @db.Text
  gpxPath      String?    @map("gpx_path")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  specimens    Specimen[]

  @@map("field_walks")
}

model Specimen {
  id             String    @id @default(cuid())
  bagNumber      String    @map("bag_number")
  nameEn         String    @map("name_en")
  namePl         String    @map("name_pl")
  nameCs         String    @map("name_cs")
  rockType       String    @map("rock_type")
  locationName   String?   @map("location_name")
  latitude       Float?
  longitude      Float?
  rawPhotoUrl    String?   @map("raw_photo_url")
  cleanPhotoUrl  String?   @map("clean_photo_url")
  status         String    @default("ROUGH") // ROUGH, IN_TUMBLE, CABINET, READY_FOR_SHOP, SOLD
  estHardness    Float?    @map("est_hardness")
  pricePln       Float?    @map("price_pln")
  qrCodeUrl      String?   @map("qr_code_url")
  
  // Custom Story details generated by Gemini AI
  storyEn        String?   @map("story_en") @db.Text
  storyPl        String?   @map("story_pl") @db.Text
  storyCs        String?   @map("story_cs") @db.Text

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  fieldWalkId    String?   @map("field_walk_id")
  fieldWalk      FieldWalk? @relation(fields: [fieldWalkId], references: [id], onDelete: SetNull)

  tumbleRunId    String?   @map("tumble_run_id")
  tumbleRun      TumbleRun? @relation(fields: [tumbleRunId], references: [id], onDelete: SetNull)

  @@map("specimens")
}

model TumbleRun {
  id            String             @id @default(cuid())
  barrelSize    String             @map("barrel_size") // e.g. "3lb"
  tumblerModel  String             @map("tumbler_model") // e.g. "Lortone 3A"
  startDate     DateTime           @map("start_date")
  endDate       DateTime?          @map("end_date")
  status        String             @default("RUNNING") // RUNNING, COMPLETED, ABANDONED
  currentStage  String             @default("STAGE_1") // STAGE_1, STAGE_2, STAGE_3, STAGE_4, BURNISHING, COMPLETED
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  specimens     Specimen[]
  stageLogs     TumbleStageLog[]

  @@map("tumble_runs")
}

model TumbleStageLog {
  id          String    @id @default(cuid())
  tumbleRunId String    @map("tumble_run_id")
  stage       String    // STAGE_1, STAGE_2, STAGE_3, STAGE_4, BURNISHING
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  gritUsed    String    @map("grit_used") // e.g. "60/90 Silicon Carbide"
  details     String?   @db.Text

  tumbleRun   TumbleRun @relation(fields: [tumbleRunId], references: [id], onDelete: Cascade)

  @@map("tumble_stage_logs")
}
